@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="container vh-100 d-flex align-items-center justify-content-center">
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden" style="max-width: 900px;">
        <div class="row g-0">
            @* Left Side: Image *@
            <div class="col-md-6 d-none d-md-block">
                <img src="~/images/clothbg.jpg" class="img-fluid h-100 w-100" style="object-fit: cover;" alt="Clothing Background">
            </div>

            @* Right Side: Form *@
            <div class="col-md-6 bg-white p-4 p-md-5 d-flex flex-column justify-content-center">
                <div class="text-center mb-4">
                    <h1 class="fw-bold text-dark mb-1">2FT</h1>
                    <p class="text-muted small text-uppercase fw-semibold" style="letter-spacing: 1px;">Create New Password</p>
                </div>

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>
                    <input asp-for="Input.Code" type="hidden" />
                    <input asp-for="Input.Email" type="hidden" />

                    <div class="mb-3">
                        <label class="small fw-bold text-muted text-uppercase mb-1">Account</label>
                        <input class="form-control border-2 py-2 bg-light shadow-none" value="@Model.Input.Email" disabled />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Password" class="small fw-bold text-muted text-uppercase mb-1">New Password</label>
                        <input asp-for="Input.Password" class="form-control border-2 py-2 shadow-none" placeholder="••••••••" autocomplete="new-password" />
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.ConfirmPassword" class="small fw-bold text-muted text-uppercase mb-1">Confirm Password</label>
                        <input asp-for="Input.ConfirmPassword" class="form-control border-2 py-2 shadow-none" placeholder="••••••••" autocomplete="new-password" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-dark btn-lg w-100 rounded-pill fw-bold shadow-sm py-2" style="background-color: #212529;">
                        Update Password
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}