@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="container vh-100 d-flex align-items-center justify-content-center">
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden" style="max-width: 900px;">
        <div class="row g-0">
            @* Left Side: Image *@
            <div class="col-md-6 d-none d-md-block">
                <img src="~/images/clothbg.jpg" class="img-fluid h-100 w-100" style="object-fit: cover;" alt="Clothing Background">
            </div>

            @* Right Side: Form *@
            <div class="col-md-6 bg-white p-4 p-md-5 d-flex flex-column justify-content-center">
                <div class="text-center mb-4">
                    <h1 class="fw-bold text-dark mb-1">2FT</h1>
                    <p class="text-muted small text-uppercase fw-semibold" style="letter-spacing: 1px;">Reset Access</p>
                </div>

                @* Added id to match your JS *@
                <form method="post" id="forgotPasswordForm">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                    <div class="mb-4">
                        <label asp-for="Input.Email" class="small fw-bold text-muted text-uppercase mb-1">Email address</label>
                        <input asp-for="Input.Email" class="form-control border-2 py-2 shadow-none"
                               placeholder="admin@2ft.com" autocomplete="username" />
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    @* Added id and spinner span to match your JS *@
                    <button type="submit" id="submitBtn" class="btn btn-dark btn-lg w-100 rounded-pill fw-bold shadow-sm mb-4 py-2" style="background-color: #212529;">
                        <span id="btnSpinner" class="spinner-border spinner-border-sm d-none me-2" role="status"></span>
                        <span id="btnText">Send Reset Link</span>
                    </button>

                    <div class="text-center border-top pt-3">
                        <p class="small text-muted mb-0">
                            Remember your password?
                            <a asp-page="./Login" class="text-dark fw-bold text-decoration-none ms-1">Sign In</a>
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    @* Link your external JS file here *@
    <script src="~/js/forgot-password.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            // Check if TempData from C# says we should show the alert
            var showAlert = '@TempData["ShowAlert"]';
            var email = '@TempData["UserEmail"]';

            if (showAlert === "true") {
                window.showResetSuccessAlert(email);
            }
        });
    </script>
}