<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 2FT Clothing</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100 bg-light">

    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm py-3 mb-4">
            <div class="container">
                <a class="navbar-brand fw-bold fs-4 text-dark mb-0" asp-area="" asp-controller="Home" asp-action="Index" style="letter-spacing: 1px;">
                    2FT
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-medium px-3" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-medium px-3" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>

                    <div class="navbar-nav">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="mt-auto py-3 bg-white border-top">
        <div class="container text-center">
            <p class="text-dark mb-0 small">
                &copy; 2026 <span class="fw-bold ms-1">2FT</span> by Maturan Renno
            </p>
        </div>
    </footer>

    <div class="modal fade" id="loginModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="modal-body p-0">
                    <div class="row g-0">
                        <div class="col-lg-6 d-none d-lg-block" style=" background: url(' @Url.Content("~/images/clothbg.jpg")') center center / cover no-repeat; min-height: 600px;">
                        </div>
                        <div class="col-lg-6 p-4 p-md-5 d-flex flex-column justify-content-center position-relative">
                            <button type="button" class="btn-close position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Close"></button>
                            <div class="text-center mb-4">
                                <h1 class="fw-bold mb-1" style="letter-spacing: 2px;">2FT</h1>
                                <p class="text-muted small">Welcome back to your favorite style destination.</p>
                            </div>
                            <form id="account" asp-area="Identity" asp-page="/Account/Login" method="post">
                                <div class="form-floating mb-3">
                                    <input name="Input.Email" class="form-control" autocomplete="username" placeholder="name@example.com" required />
                                    <label>Email address</label>
                                </div>
                                <div class="form-floating mb-3">
                                    <input name="Input.Password" type="password" class="form-control" autocomplete="current-password" placeholder="password" required />
                                    <label>Password</label>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mb-4">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="Input.RememberMe" value="true" />
                                        <label class="form-check-label text-muted small">Remember me</label>
                                    </div>
                                    <a asp-area="Identity" asp-page="/Account/ForgotPassword" class="text-decoration-none small text-dark fw-semibold">Forgot?</a>
                                </div>
                                <button type="submit" class="w-100 btn btn-lg btn-dark rounded-pill shadow-sm">Sign In</button>
                            </form>
                            <div class="text-center mt-4 pt-2 border-top">
                                <p class="mb-1 text-muted small">
                                    Don't have an account?
                                    <a href="#" class="text-dark fw-bold text-decoration-none" data-bs-toggle="modal" data-bs-target="#registerModal">Register here</a>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="registerModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="modal-body p-0">
                    <div class="row g-0">
                        <div class="col-lg-6 d-none d-lg-block" style=" background: url(' @Url.Content("~/images/clothbg.jpg")') center center / cover no-repeat; min-height: 600px;">
                        </div>
                        <div class="col-lg-6 p-4 p-md-5 d-flex flex-column justify-content-center position-relative">
                            <button type="button" class="btn-close position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Close"></button>
                            <div class="text-center mb-4">
                                <h1 class="fw-bold mb-1" style="letter-spacing: 2px;">2FT</h1>
                                <p class="text-muted small">Create an account to unlock exclusive styles.</p>
                            </div>
                            <form id="registerForm" asp-area="Identity" asp-page="/Account/Register" method="post">
                                <div class="form-floating mb-3">
                                    <input name="Input.Email" class="form-control" autocomplete="username" placeholder="name@example.com" required />
                                    <label>Email address</label>
                                </div>
                                <div class="form-floating mb-3">
                                    <input name="Input.Password" type="password" class="form-control" autocomplete="new-password" placeholder="password" required />
                                    <label>Password</label>
                                </div>
                                <div class="form-floating mb-4">
                                    <input name="Input.ConfirmPassword" type="password" class="form-control" autocomplete="new-password" placeholder="confirm password" required />
                                    <label>Confirm Password</label>
                                </div>
                                <button type="submit" class="w-100 btn btn-lg btn-dark rounded-pill shadow-sm">Create Account</button>
                            </form>
                            <div class="text-center mt-4 pt-2 border-top">
                                <p class="mb-1 text-muted small">
                                    Already have an account?
                                    <a href="#" class="text-dark fw-bold text-decoration-none" data-bs-toggle="modal" data-bs-target="#loginModal">Log in here</a>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        $(document).ready(function () {
            const urlParams = new URLSearchParams(window.location.search);
            // Reopen Login if failed
            if (urlParams.has('loginFailed')) {
                new bootstrap.Modal(document.getElementById('loginModal')).show();
            }
            // Reopen Register if failed
            if (urlParams.has('registerFailed')) {
                new bootstrap.Modal(document.getElementById('registerModal')).show();
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>