<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 2FT Clothing</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">

    <div class="d-flex">
        @* Only show sidebar if the user is logged in *@
        @if (User.Identity.IsAuthenticated)
        {
            <nav class="bg-dark border-end shadow-sm p-4 d-flex flex-column" style="width: 260px; min-height: 100vh;">
                <div class="text-center mb-5">
                    <h4 class="fw-bolder fs-3 text-light">2FT</h4>
                    <p class="small text-light">Control Panel</p>
                </div>

                <ul class="nav flex-column gap-3">
                    <li class="nav-item">
                        <a asp-controller="Home" asp-action="Index" class="nav-link text-dark fw-medium px-3 rounded bg-light">
                            <i class="bi bi-speedometer2 me-2"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="Products" asp-action="Index" class="nav-link text-dark fw-medium px-3 rounded bg-light">
                            <i class="bi bi-box-seam me-2"></i> Manage Products
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="Home" asp-action="Privacy" class="nav-link text-dark fw-medium px-3 rounded bg-light">
                            <i class="bi bi-shield-lock me-2"></i> Privacy
                        </a>
                    </li>
                </ul>

               <div class="mt-auto text-center gap-3">
                    <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                        <button type="submit" class="btn btn-light btn-sm w-100">
                            <i class="bi bi-box-arrow-right me-2"></i>Logout
                        </button>
                    </form>
                </div>
            </nav>
        }

        @* If logged in, content stays in the flex-grow area. 
           If logged out, we center the content perfectly. *@
        <main role="main" class="flex-grow-1 @(User.Identity.IsAuthenticated ? "p-4" : "d-flex align-items-center justify-content-center vh-100")">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>