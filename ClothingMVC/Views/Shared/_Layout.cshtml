<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 2FT Clothing</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">

    <div class="d-flex">
        <nav class="bg-white border-end shadow-sm p-4" style="width: 260px; min-height: 100vh;">
            <div class="text-center mb-5">
                <h4 class="fw-bold fs-3 text-dark">2FT</h4>
                <p class="small text-muted">Control Panel</p>
            </div>

            <ul class="nav flex-column gap-3">
                <li class="nav-item">
                    <a asp-controller="Home" asp-action="Index" class="nav-link text-dark fw-medium px-3 rounded bg-light">
                        <i class="bi bi-speedometer2 me-2"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Products" asp-action="Index" class="nav-link text-dark fw-medium px-3 rounded">
                        <i class="bi bi-box-seam me-2"></i> Manage Products
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Home" asp-action="Privacy" class="nav-link text-dark fw-medium px-3 rounded">
                        <i class="bi bi-shield-lock me-2"></i> Privacy
                    </a>
                </li>
            </ul>

            <div class="mt-5">
                <partial name="_LoginPartial" />
            </div>
        </nav>

        <main role="main" class="flex-grow-1 p-4 pb-5">
            @RenderBody()
        </main>
    </div>

    <div class="modal fade" id="loginModal" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header"><h5 class="modal-title">Login</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                <div class="modal-body" id="loginModalBody"></div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="registerModal" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header"><h5 class="modal-title">Register</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                <div class="modal-body" id="registerModalBody"></div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Universal function to load identity forms via AJAX
        function loadIdentityModal(url, modalId, bodyId) {
            $.get(url, function (data) {
                // Find the form inside the returned page and inject it
                $('#' + bodyId).html($(data).find('form'));
                $('#' + modalId).modal('show');
            });
        }

        $(document).ready(function () {
            const urlParams = new URLSearchParams(window.location.search);
            // Handle redirect errors
            if (urlParams.has('loginFailed')) {
                loadIdentityModal('/Identity/Account/Login', 'loginModal', 'loginModalBody');
            }
            if (urlParams.has('registerFailed')) {
                loadIdentityModal('/Identity/Account/Register', 'registerModal', 'registerModalBody');
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>