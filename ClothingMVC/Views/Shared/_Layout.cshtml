<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 2FT Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-body-tertiary">

    <div class="d-flex min-vh-100">
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            @* --- ADMIN SIDEBAR --- *@
            <nav class="bg-dark text-white d-flex flex-column position-fixed vh-100 shadow-lg" style="width: 280px; z-index: 1050; border-right: 1px solid rgba(255,255,255,0.05);">

                @* Brand Header *@
                <div class="p-4 border-bottom border-white border-opacity-10 mb-3">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <h3 class="fw-black mb-0 text-white text-uppercase"
                                style="letter-spacing: 5px; font-size: 2.2rem; line-height: 1;">
                                2FT<span class="text-info">.</span>
                            </h3>
                            <small class="text-white-50 fw-bolder d-block mt-1"
                                   style="font-size: 0.7rem; letter-spacing: 2px;">
                                MANAGEMENT SYSTEM
                            </small>
                        </div>
                    </div>
                </div>

                @* Admin Profile *@
                <div class="px-4 mb-4">
                    <div class="d-flex align-items-center p-3 rounded-4" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05);">
                        <div class="position-relative">
                            @* This takes the first letter of the Username (e.g., 'S' for SuperAdmin) *@
                            <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 45px; height: 45px;">
                                <span class="fw-bold text-white">
                                    @(User.Identity.Name?[0].ToString().ToUpper() ?? "?")
                                </span>
                            </div>
                            @* Online Status Indicator *@
                            <span class="position-absolute bottom-0 end-0 p-1 bg-success border border-2 border-dark rounded-circle"></span>
                        </div>

                        <div class="ms-3 overflow-hidden">                
                            <p class="mb-0 fw-bold text-white text-truncate" style="font-size: 0.85rem; letter-spacing: 0.5px;">
                                @User.Identity.Name
                            </p>
                            <small class="text-white-50 fw-medium" style="font-size: 0.7rem; opacity: 0.8;">System Admin</small>
                        </div>
                    </div>
                </div>

                @* Navigation Menu *@
                <div class="flex-grow-1 overflow-auto px-3">
                    <p class="text-white-50 small fw-bold mb-2 ms-2" style="font-size: 0.6rem; letter-spacing: 1.5px;">ANALYTICS & DATA</p>
                    <ul class="nav flex-column gap-1 mb-4">
                        <li class="nav-item">
                            <a asp-controller="Home" asp-action="Index" class="nav-link py-2 px-3 rounded-3 d-flex align-items-center transition-all @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" && ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "bg-primary text-white shadow-sm" : "text-white-50 hover-white")">
                                <i class="bi bi-speedometer2 me-3 fs-5"></i> Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Products" asp-action="Index" class="nav-link py-2 px-3 rounded-3 d-flex align-items-center transition-all @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Products" ? "bg-primary text-white shadow-sm" : "text-white-50 hover-white")">
                                <i class="bi bi-box-seam me-3 fs-5"></i> Manage Inventory
                            </a>
                        </li>
                    </ul>

                    <p class="text-white-50 small fw-bold mb-2 ms-2" style="font-size: 0.6rem; letter-spacing: 1.5px;">SYSTEM MONITORING</p>
                    <ul class="nav flex-column gap-1">
                        <li class="nav-item">
                            @* We point to the Privacy action, but label it as Logs *@
                            <a asp-controller="Home" asp-action="Privacy" class="nav-link py-2 px-3 rounded-3 d-flex align-items-center transition-all @(ViewContext.RouteData.Values["Action"]?.ToString() == "Privacy" ? "bg-primary text-white shadow-sm" : "text-white-50 hover-white")">
                                <i class="bi bi-journal-text me-3 fs-5"></i> Activity Logs
                            </a>
                        </li>
                    </ul>
                </div>

                @* Footer Logout *@
                <div class="p-4 mt-auto">
                    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
                        <button type="submit" class="btn btn-danger btn-sm w-100 rounded-3 py-2 fw-bold shadow-sm">
                            <i class="bi bi-power me-2"></i> LOGOUT
                        </button>
                    </form>
                </div>
            </nav>
        }

        @* --- MAIN CONTENT AREA --- *@
        @* If Authenticated, use sidebar margin. If not (Login/Register), center everything. *@
        <main role="main" class="flex-grow-1 d-flex flex-column @(User.Identity.IsAuthenticated ? "p-4 p-md-5" : "justify-content-center align-items-center px-3")"
              style="@(User.Identity.IsAuthenticated ? "margin-left: 280px;" : "")">

            @if (User.Identity.IsAuthenticated)
            {
                <div class="d-flex justify-content-between align-items-center mb-5">
                    <div>
                        <h2 class="fw-bold mb-1">@ViewData["Title"]</h2>
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb mb-0" style="font-size: 0.75rem;">
                                <li class="breadcrumb-item text-primary fw-bold">ADMIN</li>
                                <li class="breadcrumb-item active text-uppercase">@ViewContext.RouteData.Values["Controller"]</li>
                            </ol>
                        </nav>
                    </div>
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <style>
        .hover-white:hover {
            color: #fff !important;
            background: rgba(255,255,255,0.05);
        }

        .transition-all {
            transition: all 0.25s ease-in-out;
        }

        .fw-black {
            font-weight: 900;
        }
    </style>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>