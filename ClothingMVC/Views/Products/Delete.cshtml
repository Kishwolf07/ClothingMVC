@model ClothingMVC.Models.Product
@{
    Layout = null;
}

<div class="p-3">
    <div class="row align-items-center">
        <div class="col-md-5 pe-md-4 border-end text-center">
            <img src="@Url.Content("~/images/" + Model.ImagePath)"
                 class="img-fluid rounded shadow-lg border"
                 style="width: 100%; max-height: 380px; object-fit: cover;" />
        </div>

        <div class="col-md-7 ps-md-4">
            <div class="mb-4">
                <div class="text-danger mb-2">
                    <i class="bi bi-exclamation-triangle-fill fs-4"></i>
                    <span class="fw-bold text-uppercase small ms-1" style="letter-spacing: 1px;">Confirm Deletion</span>
                </div>

                <h1 class="fw-bold text-dark mt-1 mb-2">@Model.Name</h1>
                <h3 class="text-muted fw-light mb-4">₱ @Model.Price.ToString("N2")</h3>

                <div class="alert alert-danger border-0 bg-danger bg-opacity-10 py-3">
                    <p class="mb-0 small fw-medium text-danger">
                        <strong>Warning:</strong> Are you sure you want to delete this product?
                        This action cannot be undone and will remove it from the inventory.
                    </p>
                </div>
            </div>

            <form asp-action="Delete">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="d-flex gap-2 pt-3 border-top mt-4">
                    <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm">
                        Confirm Delete
                    </button>
                    <button type="button" class="btn btn-light border rounded-pill px-4" data-bs-dismiss="modal">
                        Cancel
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>