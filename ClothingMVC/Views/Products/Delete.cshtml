@model ClothingMVC.Models.Product

@{
    ViewData["Title"] = "Delete Product";
}

<h2 class="mb-4 text-danger">Delete Product</h2>

<div class="card shadow p-4 col-md-6">
    <h5 class="text-danger mb-3">Are you sure you want to delete this product?</h5>

    <dl class="row">
        <dt class="col-sm-4">Name</dt>
        <dd class="col-sm-8">@Model.Name</dd>

        <dt class="col-sm-4">Price</dt>
        <dd class="col-sm-8">₱ @Model.Price.ToString("N2")</dd>

        <dt class="col-sm-4">Brand</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.Brand)</dd>
    </dl>

    <form asp-action="Delete" method="post" class="mt-3">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <button type="submit" class="btn btn-danger">Confirm Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>