@model ClothingMVC.Models.Product
@{
    Layout = null;
}

<div class="p-3">
    <div class="text-center mb-4">
        <h4 class="fw-bold text-uppercase">Create Product</h4>
    </div>

    <form asp-action="Create" method="post" enctype="multipart/form-data">
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Name" class="form-label fw-bold"></label>
                <input asp-for="Name" class="form-control" required />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Price" class="form-label fw-bold"></label>
                <input asp-for="Price" class="form-control" required />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Quantity" class="form-label fw-bold"></label>
                <input asp-for="Quantity" type="number" class="form-control" required />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Brand" class="form-label fw-bold"></label>
                <select asp-for="Brand" asp-items="Html.GetEnumSelectList<BrandType>()" class="form-select"></select>
            </div>

            <div class="col-12">
                <label asp-for="Description" class="form-label fw-bold"></label>
                <textarea asp-for="Description" class="form-control" rows="2" required></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            @* --- FILE UPLOAD --- *@
            <div class="col-12">
                <label class="form-label fw-bold">Upload Image</label>
                <input type="file" name="imageFile" id="imageFile" class="form-control" accept="image/*" required />
                <div id="preview" class="mt-2 d-none">
                    <img id="imgPreview" src="#" style="max-height: 100px;" class="img-thumbnail" />
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-4">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary">Create Product</button>
        </div>
    </form>
</div>

<script>
    document.getElementById('imageFile').onchange = function (evt) {
        const [file] = this.files;
        if (file) {
            document.getElementById('preview').classList.remove('d-none');
            document.getElementById('imgPreview').src = URL.createObjectURL(file);
        }
    }
</script>