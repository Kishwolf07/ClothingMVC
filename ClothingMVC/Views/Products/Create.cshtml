@model ClothingMVC.Models.Product
@{
    Layout = null;
}

<div class="p-3">

    <div class="text-center mb-4">
        <h4 class="fw-bold text-uppercase">Create Product</h4>
    </div>

    <form asp-action="Create">
        <div class="row g-3">

            <div class="col-md-6">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Price" class="form-label"></label>
                <input asp-for="Price" class="form-control" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            @* --- ADDED QUANTITY FIELD HERE --- *@
            <div class="col-md-6">
                <label asp-for="Quantity" class="form-label"></label>
                <input asp-for="Quantity" type="number" class="form-control" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Brand" class="form-label"></label>
                <select asp-for="Brand"
                        asp-items="Html.GetEnumSelectList<BrandType>()"
                        class="form-control">
                </select>
            </div>

            <div class="col-12">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="col-12">
                <label asp-for="ImagePath" class="form-label">Image Path</label>
                <input asp-for="ImagePath" class="form-control"
                       placeholder="Example: NIKE/Nike-shirt.jpg" />
            </div>

        </div>

        <div class="d-flex justify-content-end gap-2 mt-4">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                Cancel
            </button>

            <button type="submit" class="btn btn-primary">
                Create Product
            </button>
        </div>

    </form>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}