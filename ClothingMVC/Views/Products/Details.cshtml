@model ClothingMVC.Models.Product
@{
    Layout = null;
}

<div class="p-3">
    <div class="row align-items-center">
        <div class="col-md-5 pe-md-4 border-end text-center">
            <img src="@Url.Content("~/images/" + Model.ImagePath)"
                 class="img-fluid rounded shadow-lg border"
                 style="width: 100%; max-height: 380px; object-fit: cover;" />
        </div>

        <div class="col-md-7 ps-md-4">
            <div class="mb-4">
                <span class="text-dark fw-bold text-uppercase small" style="letter-spacing: 2px;">
                    @Html.DisplayFor(model => model.Brand)
                </span>

                <h1 class="fw-bold text-dark mt-1 mb-2">@Model.Name</h1>
                <h3 class="text-dark fw-light mb-4">₱ @Model.Price.ToString("N2")</h3>

                <h6 class="fw-bold text-muted text-uppercase small mb-2" style="letter-spacing: 1px;">Product Description</h6>
                <p class="text-secondary lh-base" style="font-size: 1.05rem;">@Model.Description</p>
            </div>

            <div class="d-flex gap-2 pt-3 border-top mt-4">
                <button type="button" class="btn btn-warning rounded-pill px-4 fw-bold shadow-sm"
                        onclick="openCrudModal('@Url.Action("Edit", new { id = Model.Id })')">
                    <i class="bi bi-pencil"></i> Edit Info
                </button>
                <button type="button" class="btn btn-light border rounded-pill px-4" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>