@model ClothingMVC.Models.Product
@{
    Layout = null;
}

<div class="p-2">
    <div class="text-center mb-4">
        <h4 class="fw-bold text-uppercase text-dark" style="letter-spacing: 2px;">Update Product</h4>
    </div>

    <form asp-action="Edit">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ImagePath" />
        <input type="hidden" asp-for="Brand" /> @* Keeps the brand value static *@

        <div class="row g-4">
            <div class="col-md-5">
                <img src="@Url.Content("~/images/" + Model.ImagePath)"
                     class="img-fluid rounded shadow-sm border"
                     style="width: 100%; height: 300px; object-fit: cover;" />
            </div>

            <div class="col-md-7">
                <div class="mb-3">
                    <label class="small fw-bold text-muted text-uppercase mb-1 d-block">Brand</label>
                    <div class="bg-light p-2 border rounded fw-bold text-dark px-3">
                        @Html.DisplayFor(modelItem => Model.Brand)
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Name" class="small fw-bold text-muted text-uppercase mb-1"></label>
                    <input asp-for="Name" class="form-control border-2 shadow-sm" />
                </div>

                <div class="mb-3">
                    <label asp-for="Price" class="small fw-bold text-muted text-uppercase mb-1"></label>
                    <div class="input-group shadow-sm">
                        <span class="input-group-text bg-white border-2 border-end-0">₱</span>
                        <input asp-for="Price" class="form-control border-2 border-start-0" />
                    </div>
                </div>

                <div class="mb-0">
                    <label asp-for="Description" class="small fw-bold text-muted text-uppercase mb-1"></label>
                    <textarea asp-for="Description" class="form-control border-2 shadow-sm" rows="3"></textarea>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-4 border-top pt-3">
            <button type="button" class="btn btn-outline-secondary px-4 rounded-pill" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-warning px-4 rounded-pill fw-bold shadow-sm">Save Changes</button>
        </div>
    </form>
</div>