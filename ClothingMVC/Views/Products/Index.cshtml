@model IEnumerable<ClothingMVC.Models.Product>

@{
    ViewData["Title"] = "Products";
    var brands = Model.Select(p => p.Brand).Distinct().OrderBy(b => b);
}

<div class="container py-4">
    <h2 class="mb-4 text-center fw-bold text-uppercase" style="letter-spacing: 2px;">Our Products</h2>

    @* --- Toolbar --- *@
    <div class="row mb-5 justify-content-center g-3">
        <div class="col-md-4">
            <div class="input-group shadow-sm">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
                <input type="text" id="productSearch" class="form-control border-start-0 py-2" placeholder="Search products...">
            </div>
        </div>
        <div class="col-md-3">
            <select id="brandFilter" class="form-select py-2 shadow-sm">
                <option value="">All Brands</option>
                @foreach (var brand in brands)
                {
                    <option value="@brand">@brand</option>
                }
            </select>
        </div>
        <div class="col-md-auto">
            <button type="button" onclick="openCrudModal('@Url.Action("Create")')" class="btn btn-dark px-4 py-2 shadow-sm">
                <i class="bi bi-plus-lg me-2"></i>New Product
            </button>
        </div>
    </div>

    @* --- The Grid --- *@
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4" id="productGrid">
        @foreach (var item in Model)
        {
            <div class="col product-item" data-name="@item.Name?.ToLower()" data-brand="@item.Brand">
                <div class="card h-100 shadow-sm border-0 rounded-3">
                    <img src="@Url.Content("~/images/" + item.ImagePath)" class="card-img-top" style="height:250px; object-fit:cover;" />

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-bold mb-1">@item.Name</h5>
                        <p class="small text-muted mb-2">@item.Brand</p>
                        <p class="card-text flex-grow-1 small text-secondary">@item.Description</p>
                        <h6 class="fw-bold mt-2">₱ @item.Price.ToString("N2")</h6>

                        <div class="mt-2">
                            <span class="badge @(item.Quantity > 0 ? "bg-dark" : "bg-danger") px-3">
                                @(item.Quantity > 0 ? $"Stock: {item.Quantity}" : "Out of Stock")
                            </span>
                        </div>
                    </div>

                    <div class="card-footer bg-white border-0 text-center pb-4">
                        <div class="d-flex justify-content-center gap-2">
                            @* Action Buttons with Fixed Click Area *@
                            <button type="button" onclick="openCrudModal('@Url.Action("Edit", new { id = item.Id })')"
                                    class="btn-admin-action btn-edit" title="Edit">
                                <i class="bi bi-pencil-fill"></i>
                            </button>

                            <button type="button" onclick="openCrudModal('@Url.Action("Details", new { id = item.Id })')"
                                    class="btn-admin-action btn-details" title="Details">
                                <i class="bi bi-eye-fill"></i>
                            </button>

                            <button type="button" onclick="openCrudModal('@Url.Action("Delete", new { id = item.Id })')"
                                    class="btn-admin-action btn-delete" title="Delete">
                                <i class="bi bi-trash3-fill"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @* Empty State *@
    <div id="noResults" class="text-center py-5 d-none">
        <h4 class="text-muted">No products found.</h4>
    </div>
</div>

@* Modal Placeholder *@
<div class="modal fade" id="crudModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom-0">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="crudModalBody"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/products.js" asp-append-version="true"></script>
}