@model IEnumerable<ClothingMVC.Models.Product>

@{
    ViewData["Title"] = "Products";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<h2 class="mb-4 text-center fw-bold">Our Products</h2>

<div class="mb-4 text-center">
    <a href="javascript:void(0)"
       onclick="openCrudModal('@Url.Action("Create", "Products")')"
       class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Create New Product
    </a>
</div>

<div class="container">
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <img src="@Url.Content("~/images/" + item.ImagePath)" class="card-img-top" style="height:250px; object-fit:cover;" />

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-bold">@item.Name</h5>
                        <strong>Brand:</strong> @Html.DisplayFor(modelItem => item.Brand)
                        <p class="card-text flex-grow-1">@item.Description</p>
                        <h6 class="text-primary fw-bold mt-2">₱ @item.Price.ToString("N2")</h6>
                    </div>

                    <div class="card-footer bg-white border-0 text-center pb-4">
                        <div class="d-flex justify-content-center gap-3">
                            <a href="javascript:void(0)" onclick="openCrudModal('@Url.Action("Edit", "Products", new { id = item.Id })')"
                               class="d-flex align-items-center justify-content-center border border-warning rounded text-warning"
                               style="width: 40px; height: 40px; text-decoration: none;" title="Edit">
                                <i class="bi bi-pencil-square"></i>
                            </a>

                            <a href="javascript:void(0)" onclick="openCrudModal('@Url.Action("Details", "Products", new { id = item.Id })')"
                               class="d-flex align-items-center justify-content-center border border-info rounded text-info"
                               style="width: 40px; height: 40px; text-decoration: none;" title="Details">
                                <i class="bi bi-info"></i>
                            </a>

                            <a href="javascript:void(0)" onclick="openCrudModal('@Url.Action("Delete", "Products", new { id = item.Id })')"
                               class="d-flex align-items-center justify-content-center border border-danger rounded text-danger"
                               style="width: 40px; height: 40px; text-decoration: none;" title="Delete">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="crudModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-bottom-0">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="crudModalBody">
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openCrudModal(url) {
            $.get(url, function (data) {
                $('#crudModalBody').html(data); 
                $('#crudModal').modal('show');
            });
        }
    </script>
}