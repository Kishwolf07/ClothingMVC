@model IEnumerable<ClothingMVC.Models.Activitylog>
@{
    ViewData["Title"] = "Activity Logs";
}

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-white border-bottom py-3">
        <div class="d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold"><i class="bi bi-list-check me-2 text-primary"></i>System Events</h5>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4" style="font-size: 0.75rem; letter-spacing: 1px;">TIMESTAMP</th>
                        <th style="font-size: 0.75rem; letter-spacing: 1px;">ADMIN</th>
                        <th style="font-size: 0.75rem; letter-spacing: 1px;">ACTION</th>
                        <th style="font-size: 0.75rem; letter-spacing: 1px;">ENTITY</th>
                        <th class="pe-4 text-end" style="font-size: 0.75rem; letter-spacing: 1px;">DETAILS</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var log in Model)
                        {
                            <tr>
                                <td class="ps-4 small text-muted">@log.Timestamp.ToString("MMM dd, yyyy hh:mm tt")</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-info-subtle text-info rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 24px; height: 24px; font-size: 0.6rem;">
                                            <i class="bi bi-person-fill"></i>
                                        </div>
                                        <span class="fw-medium">@log.AdminEmail</span>
                                    </div>
                                </td>
                                <td>
                                    @if (log.Action == "Delete")
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2">@log.Action</span>
                                    }
                                    else if (log.Action == "Create")
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-2">@log.Action</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-2">@log.Action</span>
                                    }
                                </td>
                                <td class="fw-bold small">@log.EntityName</td>
                                <td class="pe-4 text-end text-muted small">@log.Details</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-database-exclamation fs-2 d-block mb-2"></i>
                                No activity logs found in the database.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer bg-white border-top py-3 text-center">
        <small class="text-muted">Showing all activities for 2FT Management System</small>
    </div>
</div>