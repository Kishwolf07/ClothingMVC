@{
    ViewData["Title"] = "2FT Admin Dashboard";
}

<div class="container-fluid py-4 px-4 bg-light min-vh-100">
    @* Header Section *@
    <div class="row mb-4 align-items-center">
        <div class="col-md-8">
            <h1 class="fw-bolder mb-0 text-dark">Dashboard</h1>
            <p class="text-muted mb-0">Real-time inventory analytics for <strong>2FT Clothing</strong></p>
        </div>
        <div class="col-md-4 text-md-end">
            <button class="btn btn-white border shadow-sm rounded-3 me-2" onclick="window.print()">
                <i class="bi bi-download me-2"></i>Report
            </button>
            <a asp-controller="Products" asp-action="Index" class="btn btn-dark rounded-3 px-4 shadow-sm">
                <i class="bi bi-box-seam me-2"></i>Inventory
            </a>
        </div>
    </div>

    @* KPI Cards *@
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="text-muted small fw-bold text-uppercase mb-1">Categories</p>
                            <h2 class="fw-bold mb-0">@ViewBag.TotalProductTypes</h2>
                        </div>
                        <div class="text-dark bg-light rounded-3 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                            <i class="bi bi-grid-3x3-gap-fill fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="text-muted small fw-bold text-uppercase mb-1">Total Stock</p>
                            <h2 class="fw-bold mb-0">@ViewBag.TotalStock</h2>
                        </div>
                        <div class="text-primary bg-primary bg-opacity-10 rounded-3 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                            <i class="bi bi-archive-fill fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 bg-dark text-white">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="text-secondary small fw-bold text-uppercase mb-1">Status</p>
                            <h2 class="fw-bold mb-0 text-success">Active</h2>
                        </div>
                        <div class="bg-success bg-opacity-25 rounded-3 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                            <i class="bi bi-check-circle-fill fs-4 text-success"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="text-muted small fw-bold text-uppercase mb-1">Avg. Qty</p>
                            <h2 class="fw-bold mb-0">@(ViewBag.TotalProductTypes > 0 ? (ViewBag.TotalStock / ViewBag.TotalProductTypes) : 0)</h2>
                        </div>
                        <div class="text-warning bg-warning bg-opacity-10 rounded-3 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                            <i class="bi bi-lightning-charge-fill fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Analytics Section *@
    <div class="row g-4">
        @* Main Bar Chart *@
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0">Inventory by Brand</h5>
                    <ul class="nav nav-pills nav-pills-sm" id="pills-tab" role="tablist">
                        <li class="nav-item"><button class="nav-link active py-1 px-3 small border rounded-pill" data-bs-toggle="pill">Volume</button></li>
                    </ul>
                </div>
                <div style="height: 300px;">
                    <canvas id="barChart"></canvas>
                </div>
            </div>
        </div>

        @* Pie/Doughnut Chart *@
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                <h5 class="fw-bold mb-4">Brand Share %</h5>
                <div style="height: 250px;">
                    <canvas id="doughnutChart"></canvas>
                </div>
                <div class="mt-4 pt-2 border-top text-center">
                    <p class="text-muted small mb-0">Stock contribution across all active brands.</p>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Data from ViewBag
        const brandNames = @Html.Raw(Json.Serialize(ViewBag.BrandNames));
        const brandTotals = @Html.Raw(Json.Serialize(ViewBag.BrandTotals));

        //Bar Chart (Inventory Levels)
        const barCtx = document.getElementById('barChart').getContext('2d');
        new Chart(barCtx, {
            type: 'bar',
            data: {
                labels: brandNames,
                datasets: [{
                    label: 'Units',
                    data: brandTotals,
                    backgroundColor: '#212529',
                    borderRadius: 12,
                    barThickness: 35
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, grid: { borderDash: [5, 5] }, border: { display: false } },
                    x: { grid: { display: false }, border: { display: false } }
                }
            }
        });

        //Doughnut Chart (Brand Share)
        const doughnutCtx = document.getElementById('doughnutChart').getContext('2d');
        new Chart(doughnutCtx, {
            type: 'doughnut',
            data: {
                labels: brandNames,
                datasets: [{
                    data: brandTotals,
                    backgroundColor: ['#212529', '#495057', '#adb5bd', '#dee2e6', '#f8f9fa'],
                    borderWidth: 0,
                    hoverOffset: 15
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'bottom', labels: { usePointStyle: true, padding: 20 } }
                },
                cutout: '70%'
            }
        });
    </script>
}