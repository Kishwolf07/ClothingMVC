@{
    ViewData["Title"] = "2FT Admin Dashboard";
}

<div class="container-fluid py-4 px-4 bg-light min-vh-100">
    @* --- Header Section --- *@
    <div class="row mb-4 align-items-center">
        <div class="col-md-8">
            <h1 class="fw-bolder mb-0 text-dark">Dashboard</h1>
            <p class="text-muted mb-0">Real-time inventory analytics for <strong>2FT Clothing</strong></p>
        </div>
        <div class="col-md-4 text-md-end">
            <button class="btn btn-white border shadow-sm rounded-3 me-2" onclick="window.print()">
                <i class="bi bi-download me-2"></i>Report
            </button>
            <a asp-controller="Products" asp-action="Index" class="btn btn-dark rounded-3 px-4 shadow-sm">
                <i class="bi bi-box-seam me-2"></i>Inventory
            </a>
        </div>
    </div>

    @* --- KPI Cards Section --- *@
    <div class="row g-4 mb-4">
        @* Categories *@
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted small fw-bold text-uppercase mb-1">Categories</p>
                            <h2 class="fw-bold mb-0">@ViewBag.TotalProductTypes</h2>
                            <span class="text-success small fw-medium"><i class="bi bi-arrow-up-short"></i> Active Catalog</span>
                        </div>
                        <div class="text-dark bg-light rounded-3 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                            <i class="bi bi-grid-3x3-gap-fill fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* Total Stock with Alert Logic *@
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted small fw-bold text-uppercase mb-1">Total Stock</p>
                            <h2 class="fw-bold mb-0">@ViewBag.TotalStock</h2>
                            @if (ViewBag.TotalStock < 50)
                            {
                                <span class="text-danger small fw-medium"><i class="bi bi-exclamation-triangle-fill"></i> Low Inventory</span>
                            }
                            else
                            {
                                <span class="text-muted small fw-medium">Healthy Level</span>
                            }
                        </div>
                        <div class="text-primary bg-primary bg-opacity-10 rounded-3 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                            <i class="bi bi-archive-fill fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* System Status - Hard Focus Style *@
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 bg-dark text-white h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="text-secondary small fw-bold text-uppercase mb-1">Status</p>
                            <h2 class="fw-bold mb-0 text-success">Active</h2>
                            <p class="mb-0 small text-secondary">Verified @DateTime.Now.ToString("h:mm tt")</p>
                        </div>
                        <div class="bg-success bg-opacity-25 rounded-3 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                            <div class="spinner-grow spinner-grow-sm text-success" role="status"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* Average Quantity with Visual Progress *@
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <p class="text-muted small fw-bold text-uppercase mb-0">Avg. Qty</p>
                        <i class="bi bi-lightning-charge-fill text-warning"></i>
                    </div>
                    @{
                        var avg = ViewBag.TotalProductTypes > 0 ? (ViewBag.TotalStock / ViewBag.TotalProductTypes) : 0;
                    }
                    <h2 class="fw-bold mb-1">@avg</h2>
                    <div class="progress mt-2" style="height: 6px;">
                        <div class="progress-bar bg-warning" role="progressbar" style="width: 70%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* --- Analytics Section --- *@
    <div class="row g-4">
        @* Main Bar Chart *@
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0">Inventory by Brand</h5>
                    <ul class="nav nav-pills nav-pills-sm">
                        <li class="nav-item">
                            <button class="nav-link active py-1 px-3 small border rounded-pill bg-dark text-white">Volume</button>
                        </li>
                    </ul>
                </div>
                <div style="height: 300px;">
                    <canvas id="barChart"></canvas>
                </div>
            </div>
        </div>

        @* Doughnut Chart with "Center Text" Space *@
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                <h5 class="fw-bold mb-4">Brand Share %</h5>
                <div style="height: 250px; position: relative;">
                    <canvas id="doughnutChart"></canvas>
                </div>
                <div class="mt-4 pt-2 border-top text-center">
                    <p class="text-muted small mb-0">Market distribution based on current stock levels.</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Data from C# Backend
        const brandNames = @Html.Raw(Json.Serialize(ViewBag.BrandNames));
        const brandTotals = @Html.Raw(Json.Serialize(ViewBag.BrandTotals));

        // 1. Bar Chart (Sleek Dark Theme)
        const barCtx = document.getElementById('barChart').getContext('2d');
        new Chart(barCtx, {
            type: 'bar',
            data: {
                labels: brandNames,
                datasets: [{
                    label: 'Units',
                    data: brandTotals,
                    backgroundColor: '#212529',
                    hoverBackgroundColor: '#000000',
                    borderRadius: 8,
                    barThickness: 30
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { borderDash: [5, 5], drawBorder: false },
                        ticks: { color: '#adb5bd' }
                    },
                    x: {
                        grid: { display: false },
                        ticks: { color: '#212529', font: { weight: '600' } }
                    }
                }
            }
        });

        // 2. Doughnut Chart (Professional Monotone)
        const doughnutCtx = document.getElementById('doughnutChart').getContext('2d');
        new Chart(doughnutCtx, {
            type: 'doughnut',
            data: {
                labels: brandNames,
                datasets: [{
                    data: brandTotals,
                    backgroundColor: ['#212529', '#495057', '#6c757d', '#adb5bd', '#dee2e6'],
                    borderWidth: 4,
                    borderColor: '#ffffff',
                    hoverOffset: 20
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '75%',
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { usePointStyle: true, padding: 25, font: { size: 12 } }
                    }
                }
            }
        });
    </script>
}