@{
    ViewData["Title"] = "About 2FT";
}

@* We use h-100 and d-flex to ensure the container tries to fill the viewport without overflow *@
<div class="container py-3 h-100 d-flex flex-column justify-content-center">

    @* System Info Section - Reduced margins (mb-3) *@
    <div class="row align-items-center mb-3">
        <div class="col-lg-6">
            <h6 class="text-primary fw-bold text-uppercase mb-1" style="letter-spacing: 2px; font-size: 0.75rem;">The Platform</h6>
            @* Changed from display-4 to fs-2 to save vertical space *@
            <h1 class="fs-1 fw-bold mb-2">2FT</h1>
            <p class="text-muted small mb-3">
                A high-end, minimalist inventory solution designed for modern clothing brands.
                2FT streamlines warehouse operations through advanced data tracking and secure administrative controls.
            </p>
            <div class="row g-2">
                <div class="col-6">
                    @* Reduced padding from p-3 to p-2 *@
                    <div class="p-2 border rounded-3 bg-light shadow-sm">
                        <i class="bi bi-shield-check text-primary fs-4"></i>
                        <h6 class="mt-1 fw-bold small">Secure Identity</h6>
                        <p class="mb-0 text-muted" style="font-size: 0.7rem;">Role-based access for admins.</p>
                    </div>
                </div>
                <div class="col-6">
                    <div class="p-2 border rounded-3 bg-light shadow-sm">
                        <i class="bi bi-arrow-repeat text-primary fs-4"></i>
                        <h6 class="mt-1 fw-bold small">Soft Recovery</h6>
                        <p class="mb-0 text-muted" style="font-size: 0.7rem;">Restore deleted items via logs.</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-5 offset-lg-1 d-none d-lg-block">
            @* Added a max-height to the image to prevent it from pushing the content down *@
            <img src="~/images/clothbg.jpg" class="img-fluid rounded-4 shadow-lg" alt="System Concept" style="max-height: 250px; width: 100%; object-fit: cover;">
        </div>
    </div>

    @* Reduced separator margin *@
    <hr class="my-3 opacity-10">

    @* Developer Info Section *@
    <div class="row justify-content-center text-center">
        <div class="col-lg-10">
            <h6 class="text-primary fw-bold text-uppercase mb-1" style="letter-spacing: 2px; font-size: 0.75rem;">The Developer</h6>
            <h4 class="fw-bold mb-3">Crafted with Precision</h4>

            @* Reduced padding and card margins *@
            <div class="card border-0 shadow-sm rounded-4 p-3 mb-3 bg-white">
                <div class="d-md-flex align-items-center text-md-start">
                    @* Scaled down profile icon container *@
                    <div class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center mx-auto mb-2 mb-md-0 me-md-4 shadow-sm" style="width: 70px; height: 70px; font-size: 2rem; flex-shrink: 0;">
                        <i class="bi bi-person-bounding-box"></i>
                    </div>
                    <div>
                        <h5 class="mb-0 fw-bold">Renno T. Maturan</h5>
                        <p class="text-primary mb-1 small fw-bold">DEVELOPER</p>
                        <p class="text-muted mb-2" style="font-size: 0.8rem; line-height: 1.4;">
                            Specializing in full-stack web development using ASP.NET Core MVC, C#, and modern UI frameworks.
                            Passionate about creating clean-coded solutions for complex logic.
                        </p>
                        <div class="d-flex gap-2 justify-content-center justify-content-md-start">
                            <span class="badge bg-dark-subtle text-dark px-2 py-1 rounded-pill" style="font-size: 0.65rem;">ASP.NET Core</span>
                            <span class="badge bg-dark-subtle text-dark px-2 py-1 rounded-pill" style="font-size: 0.65rem;">C#</span>
                            <span class="badge bg-dark-subtle text-dark px-2 py-1 rounded-pill" style="font-size: 0.65rem;">Bootstrap</span>
                        </div>
                    </div>
                </div>
            </div>

            @* Bottom footer text made extra small to ensure fit *@
            <p class="text-muted mb-0" style="font-size: 0.75rem;">
                This project was developed as part of the Computer Science curriculum at ACT.
            </p>
        </div>
    </div>
</div>